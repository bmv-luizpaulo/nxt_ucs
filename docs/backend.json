{
  "entities": {
    "Pedido": {
      "title": "Pedido",
      "type": "object",
      "description": "Registro de pedido de crédito (UCS)",
      "properties": {
        "id": { "type": "string" },
        "data": { "type": "string", "format": "date-time" },
        "empresa": { "type": "string" },
        "cnpj": { "type": "string" },
        "programa": { "type": "string" },
        "uf": { "type": "string" },
        "do": { "type": "boolean" },
        "quantidade": { "type": "number" },
        "taxa": { "type": "number" },
        "valorTotal": { "type": "number" },
        "hashPedido": { "type": "string" },
        "linkNxt": { "type": "string" },
        "auditado": { "type": "boolean" },
        "status": { "type": "string", "enum": ["pendente", "ok", "erro"] },
        "categoria": { "type": "string", "enum": ["selo", "Saas_Tesouro_Verde", "Saas_BMV"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "empresa", "status", "categoria"]
    },
    "EntidadeSaldo": {
      "title": "Entidade de Saldo",
      "type": "object",
      "description": "Registro de saldo para Produtores ou Associações",
      "properties": {
        "id": { "type": "string" },
        "nome": { "type": "string" },
        "documento": { "type": "string" },
        "originacao": { "type": "number" },
        "movimentacao": { "type": "number" },
        "aposentado": { "type": "number" },
        "bloqueado": { "type": "number" },
        "aquisicao": { "type": "number" },
        "saldoAjustarImei": { "type": "number" },
        "saldoFinalAtual": { "type": "number" },
        "status": { "type": "string", "enum": ["disponivel", "bloqueado", "inapto"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "nome", "documento", "status"]
    }
  },
  "auth": {
    "providers": ["password"]
  },
  "firestore": {
    "/pedidos/{pedidoId}": {
      "schema": "Pedido",
      "description": "Coleção de pedidos de crédito"
    },
    "/produtores/{produtorId}": {
      "schema": "EntidadeSaldo",
      "description": "Saldos de produtores rurais"
    },
    "/associacoes/{associacaoId}": {
      "schema": "EntidadeSaldo",
      "description": "Saldos de associações"
    }
  }
}