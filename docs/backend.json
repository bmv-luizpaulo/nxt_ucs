
{
  "entities": {
    "Pedido": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Pedido",
      "type": "object",
      "description": "Represents a credit order (UCS - Unidade de Crédito de Carbono) with its associated details, audit status, and overall processing status.",
      "properties": {
        "id": { "type": "string" },
        "data": { "type": "string", "format": "date-time" },
        "empresa": { "type": "string" },
        "cnpj": { "type": "string" },
        "programa": { "type": "string" },
        "uf": { "type": "string" },
        "quantidade": { "type": "number" },
        "valorTotal": { "type": "number" },
        "hashPedido": { "type": "string" },
        "linkNxt": { "type": "string", "format": "uri" },
        "auditado": { "type": "boolean" },
        "status": { "type": "string", "enum": ["pendente", "ok", "erro"] },
        "categoria": { "type": "string", "enum": ["selo", "Saas_Tesouro_Verde", "Saas_BMV"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "data", "empresa", "cnpj", "quantidade", "valorTotal", "status", "categoria", "createdAt"]
    },
    "Movimento": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Movimento",
      "type": "object",
      "description": "Represents an individual movement or transaction of credits associated with a specific Pedido.",
      "properties": {
        "id": { "type": "string" },
        "pedidoId": { "type": "string" },
        "raw": { "type": "string" },
        "hashMovimento": { "type": "string" },
        "tipo": { "type": "string" },
        "origem": { "type": "string" },
        "destino": { "type": "string" },
        "quantidade": { "type": "number" },
        "duplicado": { "type": "boolean" },
        "validado": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "pedidoId", "hashMovimento", "origem", "destino", "quantidade", "createdAt"]
    },
    "EntidadeSaldo": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "EntidadeSaldo",
      "type": "object",
      "description": "Represents a producer or association with their UCS balances and audit history.",
      "properties": {
        "id": { "type": "string" },
        "nome": { "type": "string" },
        "documento": { "type": "string" },
        "originacao": { "type": "number" },
        "movimentacao": { "type": "number" },
        "aposentado": { "type": "number" },
        "bloqueado": { "type": "number" },
        "aquisicao": { "type": "number" },
        "saldoAjustarImei": { "type": "number" },
        "saldoFinalAtual": { "type": "number" },
        "saldoLegadoTotal": { "type": "number" },
        "status": { "type": "string", "enum": ["disponivel", "bloqueado", "inapto"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "nome", "documento", "status", "createdAt"]
    }
  },
  "auth": {
    "providers": ["password"]
  },
  "firestore": {
    "structure": [
      {
        "path": "/pedidos/{pedidoId}",
        "definition": {
          "entityName": "Pedido",
          "description": "Main collection for credit orders."
        }
      },
      {
        "path": "/pedidos/{pedidoId}/movimentos/{movimentoId}",
        "definition": {
          "entityName": "Movimento",
          "description": "Subcollection for movements associated with a Pedido."
        }
      },
      {
        "path": "/produtores/{produtorId}",
        "definition": {
          "entityName": "EntidadeSaldo",
          "description": "Collection for individual producer balances and audit."
        }
      },
      {
        "path": "/associacoes/{associacaoId}",
        "definition": {
          "entityName": "EntidadeSaldo",
          "description": "Collection for association balances and audit."
        }
      }
    ]
  }
}
