rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Permissão total para usuários autenticados em todas as coleções e subcoleções.
    // Isso garante que a auditoria e a listagem de pedidos funcionem sem erros de permissão.
    match /{document=**} {
      allow read, write: if request.auth != null;
    }
  }
}