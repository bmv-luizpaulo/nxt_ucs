rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Permissão total para qualquer usuário autenticado em qualquer coleção ou subcoleção
    // Isso resolve o erro de "Missing or insufficient permissions" para usuários logados
    match /{document=**} {
      allow read, write: if request.auth != null;
    }
  }
}