rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Permissão total para qualquer usuário autenticado.
    // Isso resolve o erro de 'Missing or insufficient permissions' em qualquer coleção ou subcoleção.
    match /{document=**} {
      allow read, write: if request.auth != null;
    }
  }
}