rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * CORE PHILOSOPHY
     * Para este protótipo de auditoria, permitimos que qualquer usuário autenticado
     * (incluindo logins anônimos automáticos) visualize e gerencie os pedidos, movimentos,
     * produtores e associações.
     */

    // --- Funções Auxiliares Globais ---

    function isSignedIn() {
      return request.auth != null;
    }

    // Simplificado para o protótipo: qualquer usuário logado é considerado auditor
    function isAuditor() {
      return isSignedIn();
    }

    // --- Regras de Coleção ---

    match /roles_auditor/{userId} {
      allow get: if isSignedIn() && request.auth.uid == userId;
      allow list, write: if false;
    }

    match /pedidos/{pedidoId} {
      allow read, write: if isAuditor();
    }

    match /pedidos/{pedidoId}/movimentos/{movimentoId} {
      allow read, write: if isAuditor();
    }
    
    match /produtores/{produtorId} {
      allow read, write: if isAuditor();
    }
    
    match /associacoes/{associacaoId} {
      allow read, write: if isAuditor();
    }

    match /system_metadata/unique_movimento_hashes/{hashMovimento} {
      allow read: if isAuditor();
      allow write: if false;
    }
  }
}